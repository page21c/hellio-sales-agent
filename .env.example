# ============================================================
# HELLIO BRIDGE 영업 자동화 에이전트 — 환경변수
# ============================================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요
# cp .env.example .env

# 공공데이터포털 — 팩토리온 공장등록필지정보 API
FACTORY_API_KEY=여기에_data.go.kr_Decoding_인증키

# 브이월드 — GIS건물통합정보 API  
VWORLD_API_KEY=여기에_브이월드_인증키

# Claude API — 콜드메일 생성용
ANTHROPIC_API_KEY=여기에_Claude_API_키

# 이메일 발송 (Gmail SMTP 사용)
SMTP_EMAIL=helliobridge@gmail.com
SMTP_PASSWORD=여기에_Gmail_앱비밀번호
SMTP_FROM_NAME=HELLIO BRIDGE

# Supabase — 리드/결과 저장
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=여기에_Supabase_anon_key

# 스케줄러 설정
DAILY_COLLECT_HOUR=6
DAILY_EMAIL_HOUR=9
MAX_EMAILS_PER_DAY=30

# CSV 파일 경로 (초기 공장 데이터)
CSV_PATH=data/factories.csv
